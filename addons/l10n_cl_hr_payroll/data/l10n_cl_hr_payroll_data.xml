        <record id="hr_rule_sueldo_base" model="hr.salary.rule">
            <field name="name">SUELDO BASE</field>
            <field name="sequence" eval="1"/>
            <field name="code">SUELDO</field>
            <field name="category_id" ref="IMPONIBLE"/>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">
# En Odoo 19, worked_days es un objeto accesible por código
dias_no_trabajados = worked_days.Licencia.number_of_days if 'Licencia' in worked_days.dict else 0.0
dias_no_trabajados += worked_days.No_Trabajado.number_of_days if 'No_Trabajado' in worked_days.dict else 0.0

wage = contract.wage
# Lógica para sueldo empresarial o proporcional
if 'WORK100' in worked_days.dict and worked_days.WORK100.number_of_days &lt; 3:
    result = round((wage / 30) * worked_days.WORK100.number_of_days)
else:
    result = round(wage - ((wage / 30) * dias_no_trabajados))
            </field>
        </record>

        <record id="hr_rule_gratificacion" model="hr.salary.rule">
            <field name="name">GRATIFICACION LEGAL (25%)</field>
            <field name="sequence" eval="10"/>
            <field name="code">GRAT</field>
            <field name="category_id" ref="IMPONIBLE"/>
            <field name="condition_select">python</field>
            <field name="condition_python">result = not contract.gratificacion_legal</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">
limite = (4.75 * payslip.indicadores_id.sueldo_minimo) / 12
calculo = categories.IMPONIBLE * 0.25
result = round(min(calculo, limite))
            </field>
        </record>

